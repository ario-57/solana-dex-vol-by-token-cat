# Required for uploading to Dune. Create this in Dune with Read/Write scope.
DUNE_API_KEY=replace_me

# Dune upload-table settings.
DUNE_TABLE_NAME=solana_spot_dex_pair_category_volume
DUNE_IS_PRIVATE=false
DUNE_TABLE_DESCRIPTION=Solana Spot DEX volume by pair category, scraped daily from Blockworks.

# Blockworks query used by the public chart.
BLOCKWORKS_QUERY_ID=3056

# Seed/state CSV paths used by the GitHub Actions workflow.
HISTORICAL_CSV=data/historical_solana_spot_dex_volume_by_pair_category.csv
STATE_CSV=data/solana_spot_dex_pair_category_volume.csv
REFRESH_LOOKBACK_DAYS=7

# Optional local output and run controls.
# OUTPUT_CSV writes an extra copy of the merged CSV when set.
OUTPUT_CSV=
SYNC_INTERVAL_HOURS=24
SKIP_DUNE=false
ALLOW_EMPTY_SEED=false
